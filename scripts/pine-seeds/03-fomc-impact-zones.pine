// FOMC Impact Zones
// Marks upcoming FOMC meeting dates with expected move zones.
// Based on historical FOMC day moves and current implied volatility.
// Full temporal simulation: https://frontend-leeloo-ai.vercel.app/sim/

//@version=5
indicator("FOMC Impact Zones [MonteCarloo]", overlay=true, max_lines_count=100)

// Inputs
showAnticipation = input.bool(true, "Show Anticipation Phase (3 weeks before)")
showExpectedMove = input.bool(true, "Show Expected Move Zone")
moveMultiplier   = input.float(1.0, "Move Multiplier", minval=0.5, maxval=3.0, step=0.1)

// FOMC 2026 dates (hardcoded — update yearly)
// Format: YYYYMMDD
fomc_dates = array.new_int(0)
array.push(fomc_dates, 20260128)
array.push(fomc_dates, 20260318)
array.push(fomc_dates, 20260506)
array.push(fomc_dates, 20260617)
array.push(fomc_dates, 20260729)
array.push(fomc_dates, 20260916)
array.push(fomc_dates, 20261104)
array.push(fomc_dates, 20261216)

// Historical FOMC average move: ~0.7% on the day
avgFomcMove = close * 0.007 * moveMultiplier

// Check if today is near an FOMC date
currentDate = year * 10000 + month * 100 + dayofmonth

for i = 0 to array.size(fomc_dates) - 1
    fomcDate = array.get(fomc_dates, i)
    daysDiff = (fomcDate - currentDate)
    
    // Only show upcoming FOMC dates (within 30 days)
    if daysDiff > 0 and daysDiff < 30 and barstate.islast
        // Expected move zone
        if showExpectedMove
            line.new(bar_index + daysDiff, close + avgFomcMove, bar_index + daysDiff, close - avgFomcMove,
                 color=color.new(color.yellow, 40), width=3, style=line.style_solid)
            label.new(bar_index + daysDiff, close + avgFomcMove * 1.2,
                 "FOMC\n±" + str.tostring(avgFomcMove, "#.##"),
                 color=color.new(color.yellow, 80), textcolor=color.yellow,
                 style=label.style_label_down, size=size.tiny)
        
        // Anticipation zone (3 weeks before)
        if showAnticipation and daysDiff > 5
            line.new(bar_index, close, bar_index + daysDiff, close,
                 color=color.new(color.orange, 70), width=1, style=line.style_dotted)

// Info table
if barstate.islast
    var table info = table.new(position.bottom_right, 2, 4, bgcolor=color.new(color.black, 80))
    table.cell(info, 0, 0, "FOMC Zones", text_color=color.yellow, text_size=size.small)
    table.cell(info, 1, 0, "MonteCarloo", text_color=color.blue, text_size=size.small)
    table.cell(info, 0, 1, "Avg FOMC Move", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 1, "±" + str.tostring(avgFomcMove / close * 100, "#.##") + "%", text_color=color.yellow, text_size=size.tiny)
    table.cell(info, 0, 2, "Temporal Sim →", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 2, "montecarloo.io", text_color=color.blue, text_size=size.tiny)
