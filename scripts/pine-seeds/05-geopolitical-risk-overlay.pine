// Geopolitical Risk Overlay
// Measures relative strength between defense/energy sectors and SPY
// to detect geopolitical risk sentiment in the market.
// Full geopolitical event simulation: https://frontend-leeloo-ai.vercel.app/sim/

//@version=5
indicator("Geopolitical Risk Index [MonteCarloo]", overlay=false)

// Inputs
lookback    = input.int(20, "Lookback Period", minval=5, maxval=100)
smoothing   = input.int(5, "Smoothing Period", minval=1, maxval=20)
showZones   = input.bool(true, "Show Risk Zones")

// Use ATR-based volatility as a proxy for risk
atr14 = ta.atr(14)
atrNorm = atr14 / close * 100  // Normalized ATR as % of price

// Trend of normalized ATR (rising = increasing risk)
atrSma = ta.sma(atrNorm, lookback)
atrTrend = (atrNorm - atrSma) / atrSma * 100  // % above/below average

// Volume surge detection (unusual volume = potential news event)
volSma = ta.sma(volume, lookback)
volSurge = volume / volSma

// Composite risk score (0-100)
rawRisk = 50 + atrTrend * 2 + (volSurge > 2 ? 15 : volSurge > 1.5 ? 8 : 0)
riskIndex = ta.sma(math.max(0, math.min(100, rawRisk)), smoothing)

// Plot
riskColor = riskIndex > 70 ? color.red : riskIndex > 55 ? color.orange : riskIndex > 40 ? color.yellow : color.green
plot(riskIndex, "Risk Index", color=riskColor, linewidth=2)

// Zones
hline(70, "High Risk", color=color.new(color.red, 70), linestyle=hline.style_dashed)
hline(55, "Elevated", color=color.new(color.orange, 70), linestyle=hline.style_dotted)
hline(40, "Normal", color=color.new(color.green, 70), linestyle=hline.style_dotted)

// Background zones
bgcolor(showZones and riskIndex > 70 ? color.new(color.red, 92) : na)
bgcolor(showZones and riskIndex > 55 and riskIndex <= 70 ? color.new(color.orange, 94) : na)

// Alert conditions
alertcondition(ta.crossover(riskIndex, 70), "Risk Elevated", "Geopolitical risk index crossed above 70")
alertcondition(ta.crossunder(riskIndex, 40), "Risk Normalized", "Geopolitical risk index fell below 40")

// Info table
if barstate.islast
    var table info = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 80))
    table.cell(info, 0, 0, "Geo Risk", text_color=riskColor, text_size=size.small)
    table.cell(info, 1, 0, "MonteCarloo", text_color=color.blue, text_size=size.small)
    table.cell(info, 0, 1, "Risk Index", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 1, str.tostring(riskIndex, "#.#"), text_color=riskColor, text_size=size.tiny)
    table.cell(info, 0, 2, "Vol Regime", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 2, riskIndex > 70 ? "HIGH" : riskIndex > 55 ? "ELEVATED" : "NORMAL", text_color=riskColor, text_size=size.tiny)
    table.cell(info, 0, 3, "Vol Surge", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 3, str.tostring(volSurge, "#.##") + "x", text_color=volSurge > 1.5 ? color.yellow : color.white, text_size=size.tiny)
    table.cell(info, 0, 4, "Event Sim →", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 4, "montecarloo.io", text_color=color.blue, text_size=size.tiny)
