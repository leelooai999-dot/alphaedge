// Event Impact Visualizer
// Draws forward-looking projection zones based on event probability and severity.
// Use with MonteCarloo's Monte Carlo simulator for full scenario analysis.
// Try it free: https://frontend-leeloo-ai.vercel.app/sim/

//@version=5
indicator("Event Impact Visualizer [MonteCarloo]", overlay=true, max_lines_count=500)

// Inputs
eventProb    = input.float(0.65, "Event Probability (0-1)", minval=0, maxval=1, step=0.05)
eventSeverity = input.float(5.0, "Impact Severity (1-10)", minval=1, maxval=10, step=0.5)
direction    = input.string("Bullish", "Direction", options=["Bullish", "Bearish"])
horizonBars  = input.int(30, "Projection Horizon (bars)", minval=5, maxval=252)
showBands    = input.bool(true, "Show Confidence Bands")
showMedian   = input.bool(true, "Show Median Line")

// Calculate expected move
dailyVol     = ta.stdev(math.log(close / close[1]), 20) * math.sqrt(252)
annualVol    = dailyVol
expectedMove = close * eventProb * (eventSeverity / 10) * annualVol * math.sqrt(horizonBars / 252)

// Direction multiplier
dirMult = direction == "Bullish" ? 1.0 : -1.0

// Project prices
medianTarget = close + dirMult * expectedMove
upperBand    = close + dirMult * expectedMove * 1.5
lowerBand    = close + dirMult * expectedMove * 0.5

// Draw projection lines on last bar
if barstate.islast
    // Median projection
    if showMedian
        medianLine = line.new(bar_index, close, bar_index + horizonBars, medianTarget,
             color=direction == "Bullish" ? color.green : color.red,
             width=2, style=line.style_solid)
        label.new(bar_index + horizonBars, medianTarget,
             str.tostring(medianTarget, "#.##"),
             color=direction == "Bullish" ? color.green : color.red,
             textcolor=color.white, style=label.style_label_left, size=size.small)
    
    // Confidence bands
    if showBands
        upperLine = line.new(bar_index, close, bar_index + horizonBars, upperBand,
             color=color.new(color.blue, 60), width=1, style=line.style_dashed)
        lowerLine = line.new(bar_index, close, bar_index + horizonBars, lowerBand,
             color=color.new(color.blue, 60), width=1, style=line.style_dashed)
    
    // Info table
    var table info = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black, 80))
    table.cell(info, 0, 0, "Event Impact", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(info, 1, 0, "MonteCarloo", text_color=color.blue, text_size=size.small)
    table.cell(info, 0, 1, "Probability", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 1, str.tostring(eventProb * 100, "#") + "%", text_color=color.white, text_size=size.tiny)
    table.cell(info, 0, 2, "Severity", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 2, str.tostring(eventSeverity, "#.#") + "/10", text_color=color.white, text_size=size.tiny)
    table.cell(info, 0, 3, "Direction", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 3, direction, text_color=direction == "Bullish" ? color.green : color.red, text_size=size.tiny)
    table.cell(info, 0, 4, "Median Target", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 4, "$" + str.tostring(medianTarget, "#.##"), text_color=color.white, text_size=size.tiny)
    table.cell(info, 0, 5, "", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 5, "montecarloo.io", text_color=color.blue, text_size=size.tiny)
